#!/bin/sh
set -e

case "$1" in
remove | deconfigure)
	if command -v systemctl >/dev/null 2>&1; then
		systemctl disable --now lite-nas-system-metrics.service >/dev/null 2>&1 || true
	fi
	;;
upgrade | failed-upgrade)
	;;
*)
	echo "prerm called with unsupported argument: $1" >&2
	exit 1
	;;
esac

exit 0
