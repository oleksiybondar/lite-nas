{
  "$schema": "https://raw.githubusercontent.com/kucherenko/jscpd/master/schemas/jscpd-schema.json",
  "threshold": 2.5,
  "minLines": 8,
  "minTokens": 50,
  "format": ["go"],
  "reporters": ["console"],
  "absolute": true,
  "gitignore": true,
  "ignore": [
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/logs/**",
    "**/log.html",
    "**/.cache/**",
    "**/.build/**",
    "**/.artifacts/**",
    "**/shared/go/parsers/generated/**",
    "**/*.lock",
    "**/package-lock.json",
    "**/pnpm-lock.yaml",
    "**/yarn.lock",
    "**/.venv/**"
  ]
}
