abi <abi/4.0>,

include <tunables/global>

profile /usr/libexec/lite-nas/auth-service flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/lite-nas-go-base>
  include <abstractions/lite-nas-nats-client>
  include <abstractions/authentication>

  /usr/libexec/lite-nas/auth-service mr,
  /etc/lite-nas/auth.conf r,
  /etc/pam.d/litenas-auth r,
  /etc/lite-nas/certificates/auth/token-signing.crt r,
  /etc/lite-nas/certificates/auth/token-signing.key r,
  /var/log/lite-nas/auth-service.log rw,

  include if exists <local/usr.libexec.lite-nas.auth-service>
}

