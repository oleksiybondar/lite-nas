abi <abi/4.0>,

include <tunables/global>

profile /usr/libexec/lite-nas/web-gateway flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/lite-nas-go-base>
  include <abstractions/lite-nas-nats-client>
  include <abstractions/lite-nas-auth-client>

  /usr/libexec/lite-nas/web-gateway mr,
  /usr/share/lite-nas/web-gateway/ r,
  /usr/share/lite-nas/web-gateway/** r,
  /etc/lite-nas/web-gateway.conf r,
  /etc/lite-nas/certificates/auth/token-signing.crt r,
  /var/log/lite-nas/web-gateway.log rw,

  include if exists <local/usr.libexec.lite-nas.web-gateway>
}

