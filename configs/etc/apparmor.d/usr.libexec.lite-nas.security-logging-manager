abi <abi/4.0>,

include <tunables/global>

profile /usr/libexec/lite-nas/security-logging-manager flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/lite-nas-go-base>
  include <abstractions/lite-nas-nats-client>

  /usr/libexec/lite-nas/security-logging-manager mr,
  /etc/lite-nas/security-logging-manager.conf r,
  /var/log/lite-nas/security-logging-manager.log rw,
  /var/lib/lite-nas/security-logging-manager/ rw,
  /var/lib/lite-nas/security-logging-manager/** rwk,

  include if exists <local/usr.libexec.lite-nas.security-logging-manager>
}

