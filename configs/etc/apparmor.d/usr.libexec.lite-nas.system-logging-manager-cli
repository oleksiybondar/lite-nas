abi <abi/4.0>,

include <tunables/global>

profile /usr/libexec/lite-nas/system-logging-manager-cli flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/lite-nas-go-base>
  include <abstractions/lite-nas-nats-client>
  include <abstractions/lite-nas-auth-client>

  /usr/libexec/lite-nas/system-logging-manager-cli mr,
  /etc/lite-nas/system-logging-manager-cli.conf r,
  /var/log/lite-nas/system-logging-manager-cli.log rw,

  include if exists <local/usr.libexec.lite-nas.system-logging-manager-cli>
}

