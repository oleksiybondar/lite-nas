abi <abi/4.0>,

include <tunables/global>

profile /usr/libexec/lite-nas/system-metrics flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/lite-nas-go-base>
  include <abstractions/lite-nas-nats-client>

  /usr/libexec/lite-nas/system-metrics mr,
  /etc/lite-nas/system-metrics.conf r,
  /var/log/lite-nas/system-metrics.log rw,
  /proc/stat r,
  /proc/meminfo r,

  include if exists <local/usr.libexec.lite-nas.system-metrics>
}

