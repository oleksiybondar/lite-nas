#!/bin/sh
set -e

PACKAGE_ROOT="/usr/libexec/lite-nas"
DEPLOY_RUNTIME_SCRIPT="$PACKAGE_ROOT/scripts/runtime/deploy-package-runtime.sh"
INSTALL_MODE="${LITE_NAS_PACKAGE_INSTALL_MODE:-}"

configure_package_validation_mode() {
	"$DEPLOY_RUNTIME_SCRIPT" --mode validate
}

configure_package() {
	if [ "$INSTALL_MODE" = "validate" ]; then
		configure_package_validation_mode
		return 0
	fi

	# shellcheck disable=SC1091
	. /usr/share/debconf/confmodule
	db_get lite-nas/replace-nats-config || true
	REPLACE_NATS_CONFIG="$RET"
	db_stop || true

	if [ "$REPLACE_NATS_CONFIG" = "true" ]; then
		"$DEPLOY_RUNTIME_SCRIPT" --mode full
	else
		"$DEPLOY_RUNTIME_SCRIPT" --mode full --no-nats-config
	fi
}

case "$1" in
configure)
	configure_package "$@"
	;;
abort-upgrade | abort-remove | abort-deconfigure)
	;;
*)
	echo "postinst called with unsupported argument: $1" >&2
	exit 1
	;;
esac

exit 0
