#!/bin/sh
set -e

PACKAGE_ROOT="/usr/libexec/lite-nas"
DEPLOY_RUNTIME_SCRIPT="$PACKAGE_ROOT/scripts/runtime/deploy-package-runtime.sh"
INSTALL_MODE="${LITE_NAS_PACKAGE_INSTALL_MODE:-}"

run_deploy_runtime() {
	mode="$1"
	shift

	echo "[TASK] LiteNAS postinst deploy: mode=$mode args=$*" >&2
	if "$DEPLOY_RUNTIME_SCRIPT" --mode "$mode" "$@"; then
		return 0
	else
		status="$?"
		echo "[ERROR] LiteNAS postinst deploy failed: mode=$mode status=$status" >&2
		exit "$status"
	fi
}

configure_package_validation_mode() {
	run_deploy_runtime validate
}

configure_package() {
	REPLACE_NATS_CONFIG="true"
	debconf_reply=""

	if [ "$INSTALL_MODE" = "validate" ]; then
		configure_package_validation_mode
		return 0
	fi

	if command -v debconf-communicate >/dev/null 2>&1; then
		debconf_reply="$(printf 'GET lite-nas/replace-nats-config\n' | debconf-communicate lite-nas 2>/dev/null || true)"
		case "$debconf_reply" in
		"0 false")
			REPLACE_NATS_CONFIG="false"
			;;
		"0 true")
			REPLACE_NATS_CONFIG="true"
			;;
		esac
	fi

	if [ "$REPLACE_NATS_CONFIG" = "true" ]; then
		echo "[INFO] LiteNAS postinst will replace NATS configuration." >&2
		run_deploy_runtime full
	else
		echo "[WARN] LiteNAS postinst will keep existing NATS configuration." >&2
		run_deploy_runtime full --no-nats-config
	fi
}

case "$1" in
configure)
	configure_package "$@"
	;;
abort-upgrade | abort-remove | abort-deconfigure)
	;;
*)
	echo "postinst called with unsupported argument: $1" >&2
	exit 1
	;;
esac

exit 0
