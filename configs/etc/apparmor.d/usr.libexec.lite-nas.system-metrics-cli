abi <abi/4.0>,

include <tunables/global>

profile /usr/libexec/lite-nas/system-metrics-cli flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/lite-nas-go-base>
  include <abstractions/lite-nas-nats-client>

  /usr/libexec/lite-nas/system-metrics-cli mr,
  /etc/lite-nas/system-metrics-cli.conf r,
  /apparmor/.null rw,
  /dev/tty rw,
  /dev/ptmx rw,
  /dev/pts/[0-9]* rw,
  /var/log/lite-nas/system-metrics-cli.log rw,

  include if exists <local/usr.libexec.lite-nas.system-metrics-cli>
}
