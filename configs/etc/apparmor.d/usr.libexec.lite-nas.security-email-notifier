abi <abi/4.0>,

include <tunables/global>

profile /usr/libexec/lite-nas/security-email-notifier flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/lite-nas-go-base>
  include <abstractions/lite-nas-nats-client>

  /usr/libexec/lite-nas/security-email-notifier mr,
  /etc/lite-nas/security-email-notifier.conf r,
  /var/log/lite-nas/security-email-notifier.log rw,

  include if exists <local/usr.libexec.lite-nas.security-email-notifier>
}

