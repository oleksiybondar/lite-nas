abi <abi/4.0>,

include <tunables/global>

profile /usr/libexec/lite-nas/resources-monitor flags=(attach_disconnected,mediate_deleted) {
  include <abstractions/lite-nas-go-base>
  include <abstractions/lite-nas-nats-client>
  include <abstractions/lite-nas-auth-client>

  /usr/libexec/lite-nas/resources-monitor mr,
  /etc/lite-nas/resources-monitor.conf r,
  /etc/lite-nas/resources-monitor/ r,
  /etc/lite-nas/resources-monitor/** r,
  /var/log/lite-nas/resources-monitor.log rw,

  include if exists <local/usr.libexec.lite-nas.resources-monitor>
}

